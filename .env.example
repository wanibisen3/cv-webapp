# CV Tailor Web App — Environment Variables
# ──────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values below — NEVER commit .env to git
# 3. Keep ENCRYPT_KEY constant across deployments (changing it breaks stored API keys)

# ── Flask session secret ───────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=change-me-to-a-random-string

# ── Supabase ───────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Settings → API
# Use the anon key for public-facing apps (RLS enforces per-user data isolation)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<your-anon-key>

# ── Encryption key for user API keys ──────────────────────────────────────────
# Generate ONCE and never change: losing this key means users must re-enter their API keys
# Run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPT_KEY=<your-fernet-key>

# ── Optional ───────────────────────────────────────────────────────────────────
# PORT=5000     # default 5000 locally; docker-compose overrides to 8000
